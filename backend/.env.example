# Server Settings
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB Atlas or Local)
# Replace with your actual credentials
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/hexstack?retryWrites=true&w=majority

# Security (JWT)
# Change to a strong random string in production
JWT_SECRET=hexstack_secure_dashboard_secret_key_12345
